REGISTER_RATE_LIMIT_WINDOW=300
REGISTER_RATE_LIMIT_MAX=10
REGISTER_EMAIL_RATE_LIMIT_WINDOW=900
REGISTER_EMAIL_RATE_LIMIT_MAX=3
LOGIN_2FA_RATE_LIMIT_WINDOW=300
LOGIN_2FA_RATE_LIMIT_MAX=12
