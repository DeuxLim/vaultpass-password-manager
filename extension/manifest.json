{
  "manifest_version": 3,
  "name": "VaultPass Extension",
  "description": "VaultPass browser extension MVP: quick vault access and copy.",
  "version": "0.1.0",
  "homepage_url": "https://app.vaultpass.com",
  "action": {
    "default_title": "VaultPass",
    "default_popup": "popup/popup.html"
  },
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "permissions": [
    "storage",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "https://app.vaultpass.com/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": [
        "content/content.js"
      ],
      "run_at": "document_idle",
      "all_frames": true
    }
  ]
}
